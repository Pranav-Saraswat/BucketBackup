// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model StorageConfig {
  id                String   @id @default(uuid())
  provider          String   // "aws", "gcp", "azure"
  bucketName        String
  region            String?
  accessKey         String?  // Encrypted
  secretKey         String?  // Encrypted
  connectionString  String?  // Encrypted for Azure
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  backupJobs        BackupJob[]
}

model BackupJob {
  id              String   @id @default(uuid())
  name            String
  description     String?
  sourcePath      String
  cronExpression  String?
  status          String   @default("idle") // "idle", "running", "failed", "completed"
  storageConfigId String
  storageConfig   StorageConfig @relation(fields: [storageConfigId], references: [id])
  lastRun         DateTime?
  nextRun         DateTime?
  logs            BackupLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BackupLog {
  id          String   @id @default(uuid())
  jobId       String
  job         BackupJob @relation(fields: [jobId], references: [id])
  status      String
  message     String
  fileSize    BigInt?
  durationMs  Int?
  checksum    String?
  createdAt   DateTime @default(now())
}
